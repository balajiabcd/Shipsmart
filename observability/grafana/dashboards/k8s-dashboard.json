{
  "dashboard": {
    "title": "Shipsmart Kubernetes Overview",
    "tags": ["shipsmart", "kubernetes", "k8s"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Pod Count",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "count(kube_pod_info) by (namespace)",
            "legendFormat": "{{namespace}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": {"x": 6, "y": 0, "w": 10, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"shipsmart\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 16, "h": 8},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{namespace=\"shipsmart\"}",
            "legendFormat": "{{pod}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Network I/O",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 16, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"shipsmart\"}[5m])) by (pod)",
            "legendFormat": "RX {{pod}}"
          },
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"shipsmart\"}[5m])) by (pod)",
            "legendFormat": "TX {{pod}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Pod Status",
        "type": "table",
        "gridPos": {"x": 0, "y": 24, "w": 16, "h": 8},
        "targets": [
          {
            "expr": "kube_pod_status_phase{namespace=\"shipsmart\"}",
            "legendFormat": "{{phase}}"
          }
        ]
      }
    ]
  }
}