{
  "dashboard": {
    "title": "Shipsmart ML Model Performance",
    "tags": ["shipsmart", "ml", "ai"],
    "timezone": "browser",
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Prediction Count",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(increase(shipsmart_predictions_total[1h]))",
            "legendFormat": "Predictions/hour"
          }
        ]
      },
      {
        "id": 2,
        "title": "Prediction Accuracy",
        "type": "gauge",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "shipsmart_model_accuracy",
            "legendFormat": "Accuracy"
          }
        ]
      },
      {
        "id": 3,
        "title": "Prediction Latency",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(shipsmart_prediction_duration_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(shipsmart_prediction_duration_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(shipsmart_prediction_duration_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "id": 4,
        "title": "Prediction Distribution",
        "type": "piechart",
        "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "sum(shipsmart_predictions_total) by (prediction)",
            "legendFormat": "{{prediction}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Model Version",
        "type": "stat",
        "gridPos": {"x": 8, "y": 8, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "shipsmart_model_version",
            "legendFormat": "Version"
          }
        ]
      },
      {
        "id": 6,
        "title": "Feature Importance",
        "type": "bargauge",
        "gridPos": {"x": 8, "y": 12, "w": 16, "h": 8},
        "targets": [
          {
            "expr": "shipsmart_feature_importance",
            "legendFormat": "{{feature}}"
          }
        ]
      }
    ]
  }
}